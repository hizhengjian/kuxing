@startuml
skinparam backgroundColor white
skinparam defaultFontName Microsoft YaHei
skinparam handwritten false
skinparam shadowing false

title 快速开始流程图

' 定义配色
skinparam activity {
    BackgroundColor<<create>> LightCyan
    BackgroundColor<<init>> LightBlue
    BackgroundColor<<run>> LightGreen
    BackgroundColor<<check>> LightYellow
    BackgroundColor<<next>> Pink
}

start

partition "**步骤 1: 创建任务配置**" #LightCyan {
    :运行 create-task 命令;
    note right
    python cli.py create-task -p "任务名称"
    end note

    :交互式输入配置信息;
    note right
    - 代码路径
    - 文档路径
    - 项目描述
    - 最大轮次
    end note

    :生成配置文件;
    note right
    examples/my-task.yaml
    end note
}

partition "**步骤 2: 初始化项目**" #LightBlue {
    :运行 init 命令;
    note right
    python cli.py --config examples/my-task.yaml init
    end note

    :创建记忆目录结构;
    note right
    - .kuxing/memory/
    - .kuxing/memory/session/
    - .kuxing/memory/project/
    - .kuxing/memory/global/
    end note

    :生成 MEMORY.md 索引;
}

partition "**步骤 3: 运行任务**" #LightGreen {
    :选择执行模式;

    if (执行模式?) then (串行模式)
        :python cli.py --config <file> run --mode serial;
        note right
        顺序执行，完成后停止
        end note
    elseif (循环模式) then
        :python cli.py --config <file> run --mode loop;
        note right
        循环执行，直到达到最大轮次
        end note
    else (干运行模式)
        :python cli.py --config <file> run --dry-run;
        note right
        模拟执行，不实际运行
        end note
    endif

    :任务执行中...;
}

partition "**步骤 4: 查看状态**" #LightYellow {
    :查看当前状态;
    note right
    python cli.py --config <file> status
    end note

    :查看执行历史;
    note right
    python cli.py --config <file> history
    end note
}

partition "**步骤 5: 下一步**" #Pink {
    :学习更多功能;
    note right
    - 配置指南（05-config-guide.md）
    - 命令参考（04-commands.md）
    - 使用案例（09-examples.md）
    - 最佳实践（10-best-practices.md）
    end note
}

stop

legend right
    |= 颜色 |= 阶段 |
    |<#LightCyan>| 创建配置 |
    |<#LightBlue>| 初始化项目 |
    |<#LightGreen>| 运行任务 |
    |<#LightYellow>| 查看状态 |
    |<#Pink>| 下一步 |
endlegend

@enduml
